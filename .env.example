# AumOS Auth Gateway — Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# Core AumOS settings (aumos-common.config.AumOSSettings)
# -----------------------------------------------------------------------
AUMOS_SERVICE_NAME=aumos-auth-gateway
AUMOS_ENVIRONMENT=development
AUMOS_DEBUG=true

# PostgreSQL (asyncpg)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_DATABASE__POOL_SIZE=10
AUMOS_DATABASE__MAX_OVERFLOW=5

# Kafka
AUMOS_KAFKA__BROKERS=localhost:9092

# Observability
AUMOS_OTEL_ENDPOINT=http://localhost:4317
AUMOS_LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------
# Auth Gateway specific (env prefix: AUMOS_AUTH_)
# -----------------------------------------------------------------------

# Keycloak
AUMOS_AUTH_KEYCLOAK_BASE_URL=http://localhost:8080
AUMOS_AUTH_KEYCLOAK_ADMIN_REALM=master
AUMOS_AUTH_KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
AUMOS_AUTH_KEYCLOAK_ADMIN_USERNAME=admin
AUMOS_AUTH_KEYCLOAK_ADMIN_PASSWORD=admin
AUMOS_AUTH_KEYCLOAK_AUMOS_REALM=aumos
AUMOS_AUTH_KEYCLOAK_TOKEN_ISSUER=http://localhost:8080/realms/aumos
AUMOS_AUTH_KEYCLOAK_AUDIENCE=aumos-platform
AUMOS_AUTH_KEYCLOAK_ADMIN_TIMEOUT_SECONDS=30

# OPA (Open Policy Agent)
AUMOS_AUTH_OPA_BASE_URL=http://localhost:8181
AUMOS_AUTH_OPA_TIMEOUT_SECONDS=5
AUMOS_AUTH_OPA_POLICY_PREFIX=aumos

# Kong Admin API
AUMOS_AUTH_KONG_ADMIN_URL=http://localhost:8001
AUMOS_AUTH_KONG_TIMEOUT_SECONDS=10

# Agent identity settings
AUMOS_AUTH_AGENT_SECRET_MIN_LENGTH=32
AUMOS_AUTH_AGENT_SECRET_ROTATION_DAYS=90
AUMOS_AUTH_AGENT_MAX_PRIVILEGE_LEVEL=5
AUMOS_AUTH_AGENT_TOKEN_EXPIRY_MINUTES=60

# User token settings
AUMOS_AUTH_USER_TOKEN_EXPIRY_MINUTES=30
AUMOS_AUTH_REFRESH_TOKEN_EXPIRY_DAYS=7

# HITL gate
AUMOS_AUTH_HITL_REQUIRED_PRIVILEGE_LEVEL=4

# Token blacklisting (Redis TTL)
AUMOS_AUTH_TOKEN_BLACKLIST_TTL_SECONDS=86400
